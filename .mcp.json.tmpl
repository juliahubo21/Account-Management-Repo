{
  "mcpServers": {
    "affinity-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["affinity-mcp"],
      "env": {
        "AFFINITY_API_KEY": "${AFFINITY_API_KEY}"
      }
    },
    "slack": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    }
  }
}
